// This is your Prisma schema file for gl_roc
// General Ledger Rusydani on Cloud

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// COMPANY (Multi-Tenant Root)
// ============================================
model Company {
  id               String   @id @default(uuid())
  code             String   @unique @db.VarChar(20)
  name             String   @db.VarChar(200)
  npwp             String?  @db.VarChar(30)
  address          String?  @db.Text
  logoUrl          String?  @map("logo_url") @db.VarChar(500)
  baseCurrency     String   @default("IDR") @map("base_currency") @db.VarChar(3)
  timezone         String   @default("Asia/Jakarta") @db.VarChar(50)
  language         String   @default("id") @db.VarChar(10)
  subscriptionPlan String   @default("free") @map("subscription_plan") @db.VarChar(20)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  users         User[]
  branches      Branch[]
  fiscalYears   FiscalYear[]
  periods       Period[]
  departments   Department[]
  costCenters   CostCenter[]
  currencies    CompanyCurrency[]
  exchangeRates ExchangeRate[]
  roles         Role[]
  loginHistories LoginHistory[]
  coaGroups     CoaGroup[]
  chartOfAccounts ChartOfAccount[]
  journals      Journal[]
  journalLines  JournalLine[]
  bankAccounts  BankAccount[]
  bankTransactions BankTransaction[]
  bankReconciliations BankReconciliation[]

  @@map("companies")
}

// ============================================
// BRANCH
// ============================================
model Branch {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  code      String   @db.VarChar(20)
  name      String   @db.VarChar(200)
  address   String?  @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@map("branches")
}

// ============================================
// USER
// ============================================
model User {
  id           String    @id @default(uuid())
  companyId    String?   @map("company_id")
  email        String    @db.VarChar(200)
  passwordHash String    @map("password_hash") @db.VarChar(500)
  name         String    @db.VarChar(200)
  roleId       String?   @map("role_id")
  systemRole   String    @default("VIEWER") @map("system_role") @db.VarChar(50) // SUPER_ADMIN, COMPANY_ADMIN, FINANCE_MANAGER, ACCOUNTANT, VIEWER
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  twoFaEnabled Boolean   @default(false) @map("two_fa_enabled")
  twoFaSecret  String?   @map("two_fa_secret") @db.VarChar(200)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  role          Role?          @relation(fields: [roleId], references: [id], onDelete: SetNull)
  loginHistories LoginHistory[]
  createdJournals Journal[]    @relation("JournalCreator")
  postedJournals  Journal[]    @relation("JournalPoster")
  journalApprovals JournalApproval[]

  @@unique([companyId, email])
  @@map("users")
}

// ============================================
// ROLE
// ============================================
model Role {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String   @db.VarChar(100)
  description String?  @db.Text
  permissions Json     @default("[]") // Array of permission strings like ["journal.create", "report.view"]
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users   User[]

  @@unique([companyId, name])
  @@map("roles")
}

// ============================================
// FISCAL YEAR
// ============================================
model FiscalYear {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  name      String   @db.VarChar(100) // e.g., FY2025
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  status    String   @default("OPEN") @db.VarChar(20) // OPEN, CLOSED
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  periods Period[]
  journals Journal[]

  @@unique([companyId, name])
  @@map("fiscal_years")
}

// ============================================
// PERIOD
// ============================================
model Period {
  id           String   @id @default(uuid())
  fiscalYearId String   @map("fiscal_year_id")
  companyId    String   @map("company_id")
  periodNumber Int      @map("period_number") // 1-12
  name         String   @db.VarChar(50) // e.g., "January 2025"
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime @map("end_date") @db.Date
  status       String   @default("OPEN") @db.VarChar(20) // OPEN, CLOSED, LOCKED
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journals   Journal[]
  bankReconciliations BankReconciliation[]

  @@unique([fiscalYearId, periodNumber])
  @@map("periods")
}

// ============================================
// DEPARTMENT (Hierarchical)
// ============================================
model Department {
  id               String   @id @default(uuid())
  companyId        String   @map("company_id")
  code             String   @db.VarChar(20)
  name             String   @db.VarChar(200)
  parentId         String?  @map("parent_id")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  company  Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Department[] @relation("DepartmentHierarchy")
  costCenters CostCenter[]
  journalLines JournalLine[]

  @@unique([companyId, code])
  @@map("departments")
}

// ============================================
// COST CENTER
// ============================================
model CostCenter {
  id               String   @id @default(uuid())
  companyId        String   @map("company_id")
  code             String   @db.VarChar(20)
  name             String   @db.VarChar(200)
  departmentId     String?  @map("department_id")
  budgetApplicable Boolean  @default(true) @map("budget_applicable")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  journalLines JournalLine[]

  @@unique([companyId, code])
  @@map("cost_centers")
}

// ============================================
// CURRENCY (Company-specific enabled currencies)
// ============================================
model Currency {
  id            String   @id @default(uuid())
  code          String   @unique @db.VarChar(3) // ISO 4217: IDR, USD, EUR
  name          String   @db.VarChar(100)
  symbol        String   @db.VarChar(10)
  decimalPlaces Int      @default(2) @map("decimal_places")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  companies    CompanyCurrency[]
  exchangeRates ExchangeRate[]

  @@map("currencies")
}

// ============================================
// COMPANY-CURRENCY (which currencies a company uses)
// ============================================
model CompanyCurrency {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  currencyId String   @map("currency_id")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyId], references: [id], onDelete: Cascade)

  @@unique([companyId, currencyId])
  @@map("company_currencies")
}

// ============================================
// EXCHANGE RATE
// ============================================
model ExchangeRate {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  currencyId String   @map("currency_id")
  date       DateTime @db.Date
  rate       Decimal  @db.Decimal(18, 6) // Rate against base currency
  source     String   @default("manual") @db.VarChar(20) // manual, auto
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyId], references: [id], onDelete: Cascade)

  @@unique([companyId, currencyId, date])
  @@map("exchange_rates")
}

// ============================================
// LOGIN HISTORY
// ============================================
model LoginHistory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  companyId String?  @map("company_id")
  ipAddress String?  @map("ip_address") @db.VarChar(50)
  userAgent String?  @map("user_agent") @db.Text
  success   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@map("login_histories")
}

// ============================================
// COA GROUP (Chart of Accounts Group)
// ============================================
model CoaGroup {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  code        String   @db.VarChar(20)
  name        String   @db.VarChar(200)
  nameEn      String?  @map("name_en") @db.VarChar(200)
  accountType String   @map("account_type") @db.VarChar(20) // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accounts  ChartOfAccount[]

  @@unique([companyId, code])
  @@map("coa_groups")
}

// ============================================
// CHART OF ACCOUNTS (Detail Accounts)
// ============================================
model ChartOfAccount {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  coaGroupId        String   @map("coa_group_id")
  parentCoaId       String?  @map("parent_coa_id")
  code              String   @db.VarChar(30) // e.g., 1-1001-001
  name              String   @db.VarChar(200)
  nameEn            String?  @map("name_en") @db.VarChar(200)
  accountType       String   @map("account_type") @db.VarChar(20) // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  accountSubType    String?  @map("account_sub_type") @db.VarChar(50) // Current Asset, Fixed Asset, etc.
  normalBalance     String   @map("normal_balance") @db.VarChar(10) // DEBIT, CREDIT
  cashFlowCategory  String?  @map("cash_flow_category") @db.VarChar(20) // OPERATING, INVESTING, FINANCING, NON_CASH, NONE
  taxMappingCode    String?  @map("tax_mapping_code") @db.VarChar(50) // PPN, PPh21, PPh23, etc.
  psakTag           String?  @map("psak_tag") @db.VarChar(50) // PSAK/IFRS code
  isBudgetApplicable Boolean @default(false) @map("is_budget_applicable")
  isIntercompany    Boolean  @default(false) @map("is_intercompany")
  isHeader          Boolean  @default(false) @map("is_header")
  isRetainedEarnings Boolean @default(false) @map("is_retained_earnings")
  sortOrder         Int      @default(0) @map("sort_order")
  level             Int      @default(1) // 1=group header, 2=sub-group, 3=detail
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  coaGroup  CoaGroup        @relation(fields: [coaGroupId], references: [id], onDelete: Cascade)
  parent    ChartOfAccount? @relation("CoaHierarchy", fields: [parentCoaId], references: [id], onDelete: SetNull)
  children  ChartOfAccount[] @relation("CoaHierarchy")
  journalLines JournalLine[]
  bankAccounts BankAccount[]

  @@unique([companyId, code])
  @@map("chart_of_accounts")
}

// ============================================
// JOURNAL (Header)
// ============================================
model Journal {
  id               String    @id @default(uuid())
  companyId        String    @map("company_id")
  journalNumber    String    @map("journal_number") @db.VarChar(50)
  journalType      String    @default("GJ") @map("journal_type") @db.VarChar(5) // GJ, AJ, RJ, CJ, OJ, RC, IC
  journalDate      DateTime  @map("journal_date") @db.Date
  postingDate      DateTime  @map("posting_date") @db.Date
  periodId         String?   @map("period_id")
  fiscalYearId     String?   @map("fiscal_year_id")
  referenceNumber  String?   @map("reference_number") @db.VarChar(100)
  description      String?   @db.Text
  currencyCode     String    @default("IDR") @map("currency_code") @db.VarChar(3)
  exchangeRate     Decimal   @default(1) @map("exchange_rate") @db.Decimal(18, 6)
  totalDebit       Decimal   @default(0) @map("total_debit") @db.Decimal(18, 2)
  totalCredit      Decimal   @default(0) @map("total_credit") @db.Decimal(18, 2)
  status           String    @default("DRAFT") @db.VarChar(20) // DRAFT, SUBMITTED, APPROVED, POSTED, REVERSED
  reversalOfId     String?   @map("reversal_of_id")
  tags             Json?     @default("[]") // Array of tag strings
  createdBy        String    @map("created_by")
  postedBy         String?   @map("posted_by")
  postedAt         DateTime? @map("posted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period        Period?      @relation(fields: [periodId], references: [id], onDelete: SetNull)
  fiscalYear    FiscalYear?  @relation(fields: [fiscalYearId], references: [id], onDelete: SetNull)
  creator       User         @relation("JournalCreator", fields: [createdBy], references: [id])
  poster        User?        @relation("JournalPoster", fields: [postedBy], references: [id])
  reversalOf    Journal?     @relation("JournalReversal", fields: [reversalOfId], references: [id], onDelete: SetNull)
  reversals     Journal[]    @relation("JournalReversal")
  lines         JournalLine[]
  approvals     JournalApproval[]

  @@unique([companyId, journalNumber])
  @@map("journals")
}

// ============================================
// JOURNAL LINE (Detail)
// ============================================
model JournalLine {
  id              String   @id @default(uuid())
  journalId       String   @map("journal_id")
  companyId       String   @map("company_id")
  lineNumber      Int      @map("line_number")
  coaId           String   @map("coa_id")
  departmentId    String?  @map("department_id")
  costCenterId    String?  @map("cost_center_id")
  description     String?  @db.Text
  debitAmount     Decimal  @default(0) @map("debit_amount") @db.Decimal(18, 2)
  creditAmount    Decimal  @default(0) @map("credit_amount") @db.Decimal(18, 2)
  debitBase       Decimal  @default(0) @map("debit_base") @db.Decimal(18, 2)
  creditBase      Decimal  @default(0) @map("credit_base") @db.Decimal(18, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  journal      Journal         @relation(fields: [journalId], references: [id], onDelete: Cascade)
  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  coa          ChartOfAccount  @relation(fields: [coaId], references: [id])
  department   Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  costCenter   CostCenter?     @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  @@map("journal_lines")
}

// ============================================
// JOURNAL APPROVAL
// ============================================
model JournalApproval {
  id          String    @id @default(uuid())
  journalId   String    @map("journal_id")
  approverId  String    @map("approver_id")
  level       Int       @default(1)
  status      String    @default("PENDING") @db.VarChar(20) // PENDING, APPROVED, REJECTED
  comment     String?   @db.Text
  actionAt    DateTime? @map("action_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  journal  Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  approver User    @relation(fields: [approverId], references: [id])

  @@map("journal_approvals")
}

// ============================================
// BANK ACCOUNT (Phase 4)
// ============================================
model BankAccount {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  accountName     String   @map("account_name") @db.VarChar(200)
  bankName        String   @map("bank_name") @db.VarChar(100)
  accountNumber   String   @map("account_number") @db.VarChar(50)
  accountHolder   String   @map("account_holder") @db.VarChar(200)
  currencyCode    String   @map("currency_code") @db.VarChar(3)
  coaId           String   @map("coa_id") // Links to GL Asset Account
  openingBalance  Decimal  @default(0) @map("opening_balance") @db.Decimal(18, 2)
  openingDate     DateTime @map("opening_date") @db.Date
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  coa                 ChartOfAccount       @relation(fields: [coaId], references: [id])
  bankTransactions    BankTransaction[]
  bankReconciliations BankReconciliation[]

  @@unique([companyId, accountNumber])
  @@map("bank_accounts")
}

// ============================================
// BANK TRANSACTION (Phase 4)
// ============================================
model BankTransaction {
  id              String   @id @default(uuid())
  bankAccountId   String   @map("bank_account_id")
  companyId       String   @map("company_id")
  transactionDate DateTime @map("transaction_date") @db.Date
  valueDate       DateTime @map("value_date") @db.Date // Equivalent date for float handling
  transactionType String   @map("transaction_type") @db.VarChar(10) // DEBIT, CREDIT
  amount          Decimal  @map("amount") @db.Decimal(18, 2)
  reference       String?  @map("reference") @db.VarChar(200)
  description     String?  @db.Text
  status          String   @default("UNMATCHED") @db.VarChar(20) // UNMATCHED, MATCHED, RECONCILED
  journalLineId   String?  @map("journal_line_id") // Link to GL entry when matched
  isBounced       Boolean  @default(false) @map("is_bounced")
  importBatchId   String?  @map("import_batch_id") // For import tracing
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("bank_transactions")
}

// ============================================
// BANK RECONCILIATION (Phase 4)
// ============================================
model BankReconciliation {
  id                   String   @id @default(uuid())
  bankAccountId        String   @map("bank_account_id")
  companyId            String   @map("company_id")
  periodId             String   @map("period_id")
  status               String   @default("DRAFT") @db.VarChar(20) // DRAFT, IN_PROGRESS, FINALIZED, LOCKED
  bankStatementBalance Decimal  @default(0) @map("bank_statement_balance") @db.Decimal(18, 2)
  glBalance            Decimal  @default(0) @map("gl_balance") @db.Decimal(18, 2)
  adjustedBankBalance  Decimal  @default(0) @map("adjusted_bank_balance") @db.Decimal(18, 2)
  adjustedGlBalance    Decimal  @default(0) @map("adjusted_gl_balance") @db.Decimal(18, 2)
  difference           Decimal  @default(0) @map("difference") @db.Decimal(18, 2)
  finalizedBy          String?  @map("finalized_by")
  finalizedAt          DateTime? @map("finalized_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period      Period      @relation(fields: [periodId], references: [id])

  @@unique([bankAccountId, periodId])
  @@map("bank_reconciliations")
}

